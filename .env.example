# Copy to `.env` for local dev (bun run dev). On Vercel, set these as
# Environment Variables in the project settings.
# NEVER put real secrets in this example file — only in .env (which is gitignored).

# ---- Postgres -------------------------------------------------------------
# Any standard Postgres works: Neon, Supabase, Vercel Postgres, Cloud SQL, RDS,
# or a local server. Include ?sslmode=require for managed/hosted databases.
# On Vercel use a HOSTED database — localhost is not reachable from the cloud.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# DATABASE_SSL=require        # require | disable  (auto: off for localhost, on otherwise)

# ---- Email — Google Workspace SMTP relay ----------------------------------
# Host/port/user are fixed (same for everyone) and already the code defaults,
# so in practice you only need to set SMTP_PASS. The relay must be enabled in
# Workspace Admin (Apps -> Google Workspace -> Gmail -> Routing -> SMTP relay
# service) with SMTP authentication allowed. SMTP_PASS is a 16-char App Password
# on the SMTP_USER account (2-Step Verification -> App passwords).
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587                 # 587 (STARTTLS) — or 465 (SSL)
SMTP_SECURE=false             # false for 587 (STARTTLS); true for 465 (SSL)
SMTP_USER=g3@g3dc.com
SMTP_PASS=your-16-char-app-password

# ---- Addressing -----------------------------------------------------------
# The From must be a g3dc.com address (or a verified domain alias on the relay).
CONTACT_FROM=G3 — Global Green Grid <g3@g3dc.com>
CONTACT_TO=g3@g3dc.com
# CONTACT_BCC=sales@g3dc.com

# ---- Branding (shown in the emails) ---------------------------------------
COMPANY_NAME=G3 — Global Green Grid
SITE_URL=https://g3dc.com
